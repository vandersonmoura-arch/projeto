:root {
    color-scheme: dark;
    --bg-base: #060816;
    --bg-deep: #0d1328;
    --panel: rgba(10, 15, 32, 0.74);
    --panel-soft: rgba(255, 255, 255, 0.04);
    --border: rgba(148, 163, 184, 0.14);
    --text-main: #eff6ff;
    --text-muted: #9fb0d1;
    --accent: #67e8f9;
    --accent-strong: #8b5cf6;
    --accent-warm: #f97316;
    --shadow-lg: 0 30px 80px rgba(2, 6, 23, 0.5);
    --radius-lg: 32px;
    --radius-md: 24px;
    --radius-sm: 18px;
}

* {
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    margin: 0;
    min-height: 100vh;
    padding: 24px;
    font-family: "General Sans", "Segoe UI", sans-serif;
    color: var(--text-main);
    background:
        radial-gradient(circle at 12% 18%, rgba(103, 232, 249, 0.18), transparent 24%),
        radial-gradient(circle at 88% 16%, rgba(139, 92, 246, 0.18), transparent 24%),
        radial-gradient(circle at 50% 100%, rgba(249, 115, 22, 0.12), transparent 26%),
        linear-gradient(140deg, var(--bg-base), var(--bg-deep));
}

.noise-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.18;
    background-image:
        linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 34px 34px;
    mask-image: radial-gradient(circle at center, black, transparent 80%);
}

.site-header,
.hero,
.panel,
.skill-card,
.project-card,
.contact-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--panel);
    backdrop-filter: blur(22px);
    box-shadow: var(--shadow-lg);
}

.site-header {
    width: min(1180px, 100%);
    margin: 0 auto 24px;
    padding: 16px 18px;
    border-radius: 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    transition: background 0.2s ease, box-shadow 0.2s ease, backdrop-filter 0.2s ease;
}

.header-scroll {
    background: rgba(10, 15, 32, 0.85);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(30px);
}

.brand,
.site-nav a,
.header-github,
.header-cta,
.project-link {
    text-decoration: none;
}

.brand {
    color: var(--text-main);
    font-family: "Sora", sans-serif;
    font-weight: 700;
    letter-spacing: -0.03em;
}

.site-nav {
    display: flex;
    gap: 18px;
}

.site-nav a,
.header-github {
    color: var(--text-muted);
    transition: color 0.2s ease;
}

.site-nav a:hover,
.header-github:hover,
.project-link:hover {
    color: var(--text-main);
}

.site-nav a.is-active {
    color: var(--text-main);
}

.header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
}

.header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 16px;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(103, 232, 249, 0.22), rgba(139, 92, 246, 0.22));
    color: var(--text-main);
    border: 1px solid rgba(103, 232, 249, 0.2);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

main,
.site-footer {
    width: min(1180px, 100%);
    margin: 0 auto;
}

.hero {
   display:grid;
grid-template-columns:1.3fr 0.7fr;
align-items:center;
gap:10px;
}


.hero::before,
.panel::before,
.skill-card::before,
.project-card::before,
.contact-panel::before {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.01));
    pointer-events: none;
}

.eyebrow,
.section-label,
.project-badge {
    display: inline-flex;
    width: fit-content;
    padding: 8px 14px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
}

.eyebrow {
    background: rgba(103, 232, 249, 0.12);
    color: #a5f3fc;
}

.hero-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 16px;
}

.hero-stack span {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-main);
    font-size: 0.92rem;
}

.hero h1,
.section-heading h2,
.contact-panel h2 {
    font-family: "Sora", sans-serif;
    letter-spacing: -0.05em;
}

.hero h1 {
    margin: 8px 0 14px;
    font-size: clamp(2.9rem, 7vw, 5.6rem);
    line-height: 0.96;
    max-width: 14ch;
}

.hero-copy{
display:flex;
flex-direction:column;
justify-content:center;
max-width:620px;
}




.hero-text {
    max-width: 58ch;
    color: var(--text-muted);
    font-size: 1.03rem;
    line-height: 1.8;
}

.hero-actions,
.contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
}

.button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 18px;
    border-radius: 18px;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
}

.button:hover,
.header-cta:hover {
    transform: translateY(-2px);
}

.button-primary {
    background: linear-gradient(135deg, var(--accent), var(--accent-strong));
    color: #04111e;
    box-shadow: 0 18px 32px rgba(103, 232, 249, 0.18);
}

.button-secondary {
    color: var(--text-main);
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.04);
}

.button:hover {
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.25);
}

.hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 34px;
}

.hero-stats article,
.floating-card,
.skill-card,
.project-card {
    border-radius: var(--radius-sm);
    background: var(--panel-soft);
    border: 1px solid rgba(148, 163, 184, 0.1);
}

.hero-stats article {
    padding: 18px;
}

.hero-stats strong {
    display: block;
    margin-bottom: 8px;
    font-size: 1.35rem;
    color: #ffffff;
}

.hero-stats span,
.floating-card span,
.project-card p,
.skill-card p,
.contact-panel p,
.about-grid p {
    color: var(--text-muted);
    line-height: 1.75;
}

.hero-visual{
display:flex;
justify-content:center;
}

.portrait-card {
    position: relative;
    width: min(100%, 380px);
    padding: 18px;
    border-radius: 34px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.03));
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 26px 48px rgba(2, 6, 23, 0.34);
}

.portrait-glow {
    position: absolute;
    bottom: -30px;
    left: 50%;
    width: 220px;
    height: 220px;
    transform: translateX(-50%);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(103, 232, 249, 0.25), transparent 70%);
    filter: blur(40px);
    z-index: 0;
}

.portrait-card img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 24px;
}

.floating-card {
    position: absolute;
    max-width: 230px;
    padding: 16px 18px;
    box-shadow: 0 18px 34px rgba(2, 6, 23, 0.24);
}

.floating-card strong {
    display: block;
    margin-top: 8px;
    line-height: 1.45;
}

.floating-card-top {
    top: 30px;
    right: 0;
}

.floating-card-bottom {
    bottom: 28px;
    left: 8px;
}

.section {
    margin-top: 26px;
}

.section-heading {
    margin-bottom: 18px;
}

.section-label {
    background: rgba(249, 115, 22, 0.12);
    color: #fdba74;
}

.section-heading h2 {
    margin: 14px 0 0;
    max-width: 16ch;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.04;
}

.about-grid,
.skills-grid,
.project-grid {
    display: grid;
    gap: 18px;
}

.about-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
}

.panel,
.contact-panel {
    border-radius: var(--radius-md);
    padding: 24px;
}

.panel h3,
.skill-card h3,
.project-card h3 {
    margin-top: 0;
}

.skills-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
}

.skill-card {
    padding: 22px;
}

.skill-card h3,
.project-card h3 {
    margin-bottom: 10px;
    font-size: 1.2rem;
}

.project-grid {
    grid-template-columns: 1.15fr 1fr 1fr;
}

.project-card {
    padding: 24px;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
}

.project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.45);
}

.project-card-featured {
    background:
        radial-gradient(circle at top left, rgba(103, 232, 249, 0.12), transparent 35%),
        rgba(255, 255, 255, 0.04);
}

.project-badge {
    margin-bottom: 14px;
    background: rgba(139, 92, 246, 0.14);
    color: #ddd6fe;
}

.project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 0;
    margin: 18px 0 22px;
    list-style: none;
}

.project-meta li {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-main);
    font-size: 0.92rem;
}

.project-link {
    color: var(--accent);
    font-weight: 600;
}

.contact-panel {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: center;
}

.site-footer {
    padding: 30px 0 14px;
    text-align: center;
    color: var(--text-muted);
}

.site-nav a:focus,
.button:focus,
.header-cta:focus,
.header-github:focus,
.project-link:focus {
    outline: 2px solid rgba(103, 232, 249, 0.75);
    outline-offset: 2px;
}

.reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s ease, transform 0.7s ease;
}

.reveal.active {
    opacity: 1;
    transform: translateY(0);
}

@media (max-width: 1080px) {
    .hero,
    .project-grid,
    .skills-grid,
    .about-grid {
        grid-template-columns: 1fr;
    }

    .hero {
        padding: 24px;
    }

    .hero-visual {
        min-height: 460px;
    }

    .contact-panel {
        flex-direction: column;
        align-items: flex-start;
    }
}

@media (max-width: 820px) {
    .site-header {
        flex-direction: column;
        align-items: stretch;
    }

    .site-nav {
        justify-content: center;
        flex-wrap: wrap;
    }

    .header-actions {
        flex-direction: column;
    }

    .header-cta,
    .header-github {
        width: 100%;
        text-align: center;
    }

    .hero-stats {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 640px) {
    body {
        padding: 14px;
    }

    .site-header,
    .hero,
    .panel,
    .skill-card,
    .project-card,
    .contact-panel {
        border-radius: 22px;
    }

    .hero,
    .panel,
    .skill-card,
    .project-card,
    .contact-panel {
        padding: 18px;
    }

    .hero h1 {
        max-width: none;
        font-size: clamp(2.4rem, 12vw, 4rem);
    }

    .section-heading h2 {
        max-width: none;
    }

    .hero-visual {
        min-height: 380px;
    }

    .floating-card {
        position: static;
        margin-top: 14px;
        max-width: none;
    }

    .button,
    .contact-actions .button {
        width: 100%;
    }
}
